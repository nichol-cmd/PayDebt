<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <%- include('../partials/theme-init') %>
  <title>Admin Panel - PayDebt</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>

<%- include('../partials/navbar', { page: 'admin', user }) %>

<div class="container my-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <div>
      <h5 class="fw-bold mb-0">Admin Panel</h5>
      <small class="text-muted">Kelola semua pengguna aplikasi</small>
    </div>
    <span class="badge bg-danger px-3 py-2">🔐 Admin Only</span>
  </div>

  <div class="row g-3 mb-4">
    <div class="col-md-3">
      <div class="card text-center p-3">
        <div class="fs-2 fw-bold text-primary"><%= stats.totalUser %></div>
        <div class="small text-muted">Total User</div>
      </div>
    </div>
    <div class="col-md-3">
      <div class="card text-center p-3">
        <div class="fs-2 fw-bold text-danger"><%= stats.totalAdmin %></div>
        <div class="small text-muted">Total Admin</div>
      </div>
    </div>
    <div class="col-md-3">
      <div class="card text-center p-3">
        <div class="fs-2 fw-bold text-success"><%= stats.totalUtang %></div>
        <div class="small text-muted">Total Utang</div>
      </div>
    </div>
    <div class="col-md-3">
      <a href="/admin/laporan" class="text-decoration-none">
        <div class="card text-center p-3">
          <div class="fs-2 fw-bold text-warning"><%= stats.laporanBaru %></div>
          <div class="small text-muted">Laporan Baru →</div>
        </div>
      </a>
    </div>
  </div>

  <div class="row g-4 mb-4">
    <!-- Form Broadcast Pengumuman -->
    <div class="col-md-5">
      <div class="card">
        <div class="card-header">📢 Kirim Pengumuman ke Semua User</div>
        <div class="card-body">
          <div id="pesanBroadcast" class="alert d-none"></div>
          <div class="mb-2">
            <label class="form-label small">Judul Pengumuman</label>
            <input type="text" class="form-control form-control-sm" id="judulBroadcast" placeholder="cth: Pemeliharaan Server">
          </div>
          <div class="mb-3">
            <label class="form-label small">Isi Pengumuman</label>
            <textarea class="form-control form-control-sm" id="pesanBroadcastInput" rows="3" placeholder="Isi pengumuman..."></textarea>
          </div>
          <button class="btn btn-primary btn-sm w-100" onclick="kirimBroadcast()">Kirim ke Semua User</button>
        </div>
      </div>
    </div>

    <div class="col-md-7">
      <div class="card h-100">
        <div class="card-header">Aksi Cepat</div>
        <div class="card-body d-flex flex-column gap-2 justify-content-center">
          <a href="/admin/laporan" class="btn btn-outline-warning">📨 Lihat Semua Laporan Masuk</a>
          <p class="small text-muted mb-0">
            Gunakan tombol <strong>Reset Password</strong> di tabel user kalau ada yang lupa password.
            Password baru akan ditampilkan sekali saja, jangan lupa dicatat untuk diberikan ke usernya.
          </p>
        </div>
      </div>
    </div>
  </div>

  <div class="card">
    <div class="card-header">Daftar Semua User</div>
    <div class="card-body p-0">
      <div id="pesanAdmin" class="alert d-none mx-3 mt-3"></div>
      <div class="table-responsive">
        <table class="table table-hover mb-0">
          <thead class="table-light">
            <tr>
              <th>ID</th><th>Nama</th><th>Email</th><th>Role</th>
              <th>Utang</th><th>Followers</th><th>Bergabung</th><th>Aksi</th>
            </tr>
          </thead>
          <tbody>
            <% users.forEach(u => { %>
              <tr id="row-<%= u.id %>">
                <td class="text-muted small"><%= u.id %></td>
                <td class="fw-semibold">
                  <%= u.name %>
                  <% if (u.id === user.id) { %><span class="badge bg-secondary ms-1" style="font-size:10px">Saya</span><% } %>
                </td>
                <td class="small"><%= u.email %></td>
                <td><span class="badge <%= u.role === 'admin' ? 'bg-danger' : 'bg-secondary' %>"><%= u.role %></span></td>
                <td><%= u._count.utang %></td>
                <td><%= u._count.followers %></td>
                <td class="small text-muted"><%= new Date(u.createdAt).toLocaleDateString('id-ID', {day:'numeric',month:'short',year:'numeric'}) %></td>
                <td>
                  <% if (u.id !== user.id) { %>
                    <div class="d-flex gap-1 flex-wrap">
                      <button class="btn btn-sm btn-outline-primary"
                        onclick="gantiRole(<%= u.id %>, '<%= u.role === 'admin' ? 'user' : 'admin' %>', '<%= u.name %>')">
                        <%= u.role === 'admin' ? '⬇ Jadikan User' : '⬆ Jadikan Admin' %>
                      </button>
                      <button class="btn btn-sm btn-outline-warning" onclick="resetPassword(<%= u.id %>, '<%= u.name %>')">
                        🔑 Reset Password
                      </button>
                      <button class="btn btn-sm btn-outline-danger" onclick="hapusUser(<%= u.id %>, '<%= u.name %>')">Hapus</button>
                    </div>
                  <% } else { %>
                    <span class="text-muted small">—</span>
                  <% } %>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>

<!-- Modal hasil reset password - sengaja pakai modal (bukan toast) supaya admin punya waktu menyalin -->
<div class="modal fade" id="modalPassword" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h6 class="modal-title fw-bold">Password Baru</h6>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <p class="small text-muted">Password baru untuk <strong id="namaUserReset"></strong>, catat sekarang karena tidak akan ditampilkan lagi:</p>
        <div class="input-group">
          <input type="text" class="form-control fw-bold text-center" id="passwordBaruHasil" readonly>
          <button class="btn btn-outline-secondary" onclick="copyPassword()">Salin</button>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-primary" data-bs-dismiss="modal">Selesai</button>
      </div>
    </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.socket.io/4.7.2/socket.io.min.js"></script>
<script src="/js/main.js"></script>
<script>
  mulaiPolling()

  async function gantiRole(userId, roleBaru, nama) {
    if (!confirm(`Ganti role ${nama} menjadi "${roleBaru}"?`)) return
    const res  = await fetch(`/api/admin/user/${userId}/role`, {
      method: 'PATCH',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ role: roleBaru })
    })
    const data = await res.json()
    tampilPesan('pesanAdmin', res.ok ? 'success' : 'danger', data.message)
    if (res.ok) setTimeout(() => location.reload(), 1000)
  }

  async function hapusUser(userId, nama) {
    if (!confirm(`Hapus user "${nama}"? Semua data utangnya juga akan terhapus.`)) return
    const res  = await fetch(`/api/admin/user/${userId}`, { method: 'DELETE' })
    const data = await res.json()
    if (res.ok) {
      document.getElementById(`row-${userId}`).remove()
      tampilPesan('pesanAdmin', 'success', data.message)
    } else {
      tampilPesan('pesanAdmin', 'danger', data.message)
    }
  }

  async function resetPassword(userId, nama) {
    if (!confirm(`Reset password untuk "${nama}"? Password lamanya akan hilang.`)) return

    const res  = await fetch(`/api/admin/user/${userId}/reset-password`, { method: 'PATCH' })
    const data = await res.json()

    if (!res.ok) {
      tampilPesan('pesanAdmin', 'danger', data.message)
      return
    }

    document.getElementById('namaUserReset').textContent = nama
    document.getElementById('passwordBaruHasil').value = data.passwordBaru
    new bootstrap.Modal(document.getElementById('modalPassword')).show()
  }

  function copyPassword() {
    const input = document.getElementById('passwordBaruHasil')
    input.select()
    navigator.clipboard.writeText(input.value)
    tampilToast('Disalin', 'Password sudah disalin ke clipboard', 'success')
  }

  async function kirimBroadcast() {
    const judul = document.getElementById('judulBroadcast').value
    const pesan = document.getElementById('pesanBroadcastInput').value

    if (!judul || !pesan) {
      tampilPesan('pesanBroadcast', 'warning', 'Judul dan isi pengumuman harus diisi')
      return
    }

    const res  = await fetch('/api/admin/broadcast', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ judul, pesan })
    })
    const data = await res.json()
    tampilPesan('pesanBroadcast', res.ok ? 'success' : 'danger', data.message)

    if (res.ok) {
      document.getElementById('judulBroadcast').value = ''
      document.getElementById('pesanBroadcastInput').value = ''
    }
  }
</script>
</body>
</html>

<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <title>Lupa Password - PayDebt</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<div class="auth-wrap">
  <div class="auth-card">
    <div class="card">
      <div class="card-body">
        <div class="text-center mb-4">
          <span class="auth-logo">🔑</span>
          <h5 class="fw-bold mb-1">Lupa Password</h5>
          <p class="text-muted small">Masukkan email dan nama akunmu untuk verifikasi identitas</p>
        </div>

        <% if (error) { %><div class="alert alert-danger"><%= error %></div><% } %>

        <form action="/lupa-password" method="POST" novalidate>
          <div class="mb-3">
            <label class="form-label">Email</label>
            <input
              type="email"
              name="email"
              class="form-control"
              placeholder="contoh@email.com"
              required
              autofocus>
          </div>
          <div class="mb-3">
            <label class="form-label">Nama Akun</label>
            <input
              type="text"
              name="name"
              class="form-control"
              placeholder="Nama yang kamu daftarkan"
              required>
          </div>

          <button type="submit" class="btn btn-primary w-100">Verifikasi Identitas</button>
        </form>

        <p class="text-center mt-3 mb-0 small">
          <a href="/login">← Kembali ke Login</a>
        </p>
      </div>
    </div>
  </div>
</div>
</body>
</html>

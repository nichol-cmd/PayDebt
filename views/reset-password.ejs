<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <title>Reset Password - PayDebt</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<div class="auth-wrap">
  <div class="auth-card">
    <div class="card">
      <div class="card-body">
        <div class="text-center mb-4">
          <span class="auth-logo">🔒</span>
          <h5 class="fw-bold mb-1">Buat Password Baru</h5>
          <p class="text-muted small">Identitas terverifikasi sebagai <strong><%= name %></strong></p>
        </div>

        <% if (error) { %><div class="alert alert-danger"><%= error %></div><% } %>

        <form action="/reset-password" method="POST" id="formReset" novalidate>
          <!-- data verifikasi diteruskan tersembunyi, akan dicek ulang di server -->
          <input type="hidden" name="email" value="<%= email %>">
          <input type="hidden" name="name"  value="<%= name %>">

          <div class="mb-2">
            <label class="form-label">Password Baru</label>
            <div class="password-wrapper">
              <input
                type="password"
                name="passwordBaru"
                id="passwordBaru"
                class="form-control"
                placeholder="Minimal 6 karakter"
                minlength="6"
                required
                oninput="cekKekuatanPassword()">
              <button type="button" class="password-toggle" onclick="toggleLihatPassword('passwordBaru', 'iconMata1')">
                <i class="bi bi-eye-slash" id="iconMata1"></i>
              </button>
            </div>

            <div class="strength-bar mt-2">
              <div class="strength-fill" id="strengthFill"></div>
            </div>
            <div class="d-flex justify-content-between mt-1">
              <small class="text-muted">Kekuatan password:</small>
              <small id="strengthLabel" class="fw-semibold text-muted">-</small>
            </div>
          </div>

          <div class="mb-3 mt-3">
            <label class="form-label">Konfirmasi Password Baru</label>
            <div class="password-wrapper">
              <input
                type="password"
                name="konfirmasiPassword"
                id="konfirmasiPassword"
                class="form-control"
                placeholder="Ulangi password baru"
                minlength="6"
                required>
              <button type="button" class="password-toggle" onclick="toggleLihatPassword('konfirmasiPassword', 'iconMata2')">
                <i class="bi bi-eye-slash" id="iconMata2"></i>
              </button>
            </div>
            <div class="invalid-feedback-custom" id="konfirmasiFeedback"></div>
          </div>

          <button type="submit" class="btn btn-primary w-100">Ganti Password</button>
        </form>

        <p class="text-center mt-3 mb-0 small">
          <a href="/login">← Kembali ke Login</a>
        </p>
      </div>
    </div>
  </div>
</div>

<script>
  function toggleLihatPassword(inputId, iconId) {
    const input = document.getElementById(inputId)
    const icon  = document.getElementById(iconId)
    if (input.type === 'password') {
      input.type = 'text'
      icon.classList.replace('bi-eye-slash', 'bi-eye')
    } else {
      input.type = 'password'
      icon.classList.replace('bi-eye', 'bi-eye-slash')
    }
  }

  function cekKekuatanPassword() {
    const password = document.getElementById('passwordBaru').value
    const fill     = document.getElementById('strengthFill')
    const label    = document.getElementById('strengthLabel')

    if (!password) {
      fill.style.width = '0%'
      fill.className   = 'strength-fill'
      label.textContent = '-'
      label.className   = 'fw-semibold text-muted'
      return
    }

    let skor = 0
    if (password.length >= 8) skor++
    if (/[a-z]/.test(password) && /[A-Z]/.test(password)) skor++
    if (/[0-9]/.test(password)) skor++
    if (/[^a-zA-Z0-9]/.test(password)) skor++

    if (skor <= 1) {
      fill.style.width = '33%'; fill.className = 'strength-fill strength-weak'
      label.textContent = 'Lemah'; label.className = 'fw-semibold text-danger'
    } else if (skor <= 3) {
      fill.style.width = '66%'; fill.className = 'strength-fill strength-medium'
      label.textContent = 'Sedang'; label.className = 'fw-semibold text-warning'
    } else {
      fill.style.width = '100%'; fill.className = 'strength-fill strength-strong'
      label.textContent = 'Kuat'; label.className = 'fw-semibold text-success'
    }
  }

  document.getElementById('formReset').addEventListener('submit', function(e) {
    const pass1    = document.getElementById('passwordBaru').value
    const pass2    = document.getElementById('konfirmasiPassword').value
    const feedback = document.getElementById('konfirmasiFeedback')

    if (pass1 !== pass2) {
      e.preventDefault()
      feedback.textContent = 'Konfirmasi password tidak sama'
      feedback.classList.add('show')
      document.getElementById('konfirmasiPassword').classList.add('is-invalid-custom')
    }
  })
</script>
</body>
</html>

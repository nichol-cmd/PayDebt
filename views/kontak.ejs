<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <%- include('partials/theme-init') %>
  <title>Kontak - PayDebt</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>

<%- include('partials/navbar', { page: 'kontak', user }) %>

<div class="container my-4">
  <h5 class="fw-bold mb-1">Manajemen Kontak</h5>
  <p class="text-muted small mb-4">Simpan teman yang sering kamu catat utangnya, supaya bisa langsung dipilih lewat dropdown saat membuat utang baru.</p>

  <div class="row g-4">

    <!-- Tambah Kontak Baru -->
    <div class="col-md-5">
      <div class="card">
        <div class="card-header">+ Tambah Kontak Baru</div>
        <div class="card-body">
          <div class="input-group mb-2">
            <input type="text" class="form-control" id="inputCari" placeholder="Cari nama user...">
            <button class="btn btn-outline-secondary" onclick="cariUser()">Cari</button>
          </div>
          <div id="hasilCari" class="list-group"></div>
        </div>
      </div>
    </div>

    <!-- Daftar Kontak Saya -->
    <div class="col-md-7">
      <div class="card">
        <div class="card-header d-flex justify-content-between align-items-center">
          <span>Kontak Saya</span>
          <span class="badge bg-secondary" id="jumlahKontak"><%= kontak.length %></span>
        </div>
        <div id="listKontak">
          <% if (kontak.length === 0) { %>
            <div class="list-item text-muted">Belum ada kontak. Tambahkan dari form di sebelah kiri.</div>
          <% } else { %>
            <% kontak.forEach(k => { %>
              <div class="list-item d-flex justify-content-between align-items-center" id="kontak-<%= k.kontak.id %>">
                <div>
                  <div class="fw-semibold">
                    <%= k.alias || k.kontak.name %>
                    <% if (k.alias) { %>
                      <span class="small text-muted">(<%= k.kontak.name %>)</span>
                    <% } %>
                  </div>
                  <div class="small text-muted"><%= k.kontak.email %></div>
                </div>
                <div class="d-flex gap-1">
                  <button class="btn btn-sm btn-outline-secondary" onclick="ubahAlias(<%= k.kontak.id %>, '<%= k.alias || '' %>')">
                    Ubah Nama
                  </button>
                  <button class="btn btn-sm btn-outline-danger" onclick="hapusKontak(<%= k.kontak.id %>)">
                    Hapus
                  </button>
                </div>
              </div>
            <% }) %>
          <% } %>
        </div>
      </div>
    </div>

  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.socket.io/4.7.2/socket.io.min.js"></script>
<script src="/js/main.js"></script>
<script>
  mulaiPolling()

  async function cariUser() {
    const keyword = document.getElementById('inputCari').value
    if (!keyword) return

    const res  = await fetch(`/api/user/search?nama=${keyword}`)
    const data = await res.json()
    const el   = document.getElementById('hasilCari')

    if (data.data.length === 0) {
      el.innerHTML = '<div class="list-group-item small text-muted">Tidak ditemukan</div>'
      return
    }

    el.innerHTML = data.data.map(u => `
      <div class="list-group-item d-flex justify-content-between align-items-center">
        <span class="small">${u.name} <span class="text-muted">${u.email}</span></span>
        <button class="btn btn-sm btn-outline-primary" onclick="tambahKontak(${u.id}, '${u.name}')">
          + Tambah
        </button>
      </div>
    `).join('')
  }

  async function tambahKontak(id, nama) {
    const res  = await fetch(`/api/kontak/${id}`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({})
    })
    const data = await res.json()
    tampilNotifApi(res.ok, data.message)
    if (res.ok) setTimeout(() => location.reload(), 1000)
  }

  async function hapusKontak(kontakId) {
    if (!confirm('Hapus kontak ini?')) return
    const res  = await fetch(`/api/kontak/${kontakId}`, { method: 'DELETE' })
    const data = await res.json()
    tampilNotifApi(res.ok, data.message)
    if (res.ok) document.getElementById(`kontak-${kontakId}`).remove()
  }

  async function ubahAlias(kontakId, aliasLama) {
    const aliasBaru = prompt('Masukkan nama panggilan untuk kontak ini (kosongkan untuk pakai nama asli):', aliasLama)
    if (aliasBaru === null) return // user klik cancel

    const res  = await fetch(`/api/kontak/${kontakId}`, {
      method: 'PUT',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ alias: aliasBaru })
    })
    const data = await res.json()
    tampilNotifApi(res.ok, data.message)
    if (res.ok) setTimeout(() => location.reload(), 1000)
  }
</script>
</body>
</html>

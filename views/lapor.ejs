<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <%- include('partials/theme-init') %>
  <title>Lapor Masalah - PayDebt</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>

<%- include('partials/navbar', { page: 'lapor', user }) %>

<div class="container my-4">
  <h5 class="fw-bold mb-1">Lapor Masalah</h5>
  <p class="text-muted small mb-4">Menemukan bug, error, atau masalah lain? Kirim laporan ke admin di sini.</p>

  <div class="row g-4">

    <!-- Form Lapor -->
    <div class="col-md-5">
      <div class="card">
        <div class="card-header">Buat Laporan Baru</div>
        <div class="card-body">
          <div id="pesan" class="alert d-none"></div>

          <div class="mb-3">
            <label class="form-label">Judul Masalah</label>
            <input type="text" class="form-control" id="judul" placeholder="cth: Tombol konfirmasi tidak berfungsi">
          </div>
          <div class="mb-3">
            <label class="form-label">Deskripsi</label>
            <textarea class="form-control" id="deskripsi" rows="5" placeholder="Jelaskan masalahnya secara detail..."></textarea>
          </div>
          <button class="btn btn-primary w-100" onclick="kirimLaporan()">Kirim Laporan</button>
        </div>
      </div>
    </div>

    <!-- Daftar Laporan Saya -->
    <div class="col-md-7">
      <div class="card">
        <div class="card-header">Laporan Saya</div>
        <div id="listLaporan">
          <% if (laporan.length === 0) { %>
            <div class="list-item text-muted">Belum ada laporan yang dikirim</div>
          <% } else { %>
            <% laporan.forEach(l => { %>
              <div class="list-item">
                <div class="d-flex justify-content-between align-items-start">
                  <div class="fw-semibold"><%= l.judul %></div>
                  <span class="badge <%= l.status === 'SELESAI' ? 'badge-lunas' : l.status === 'DIPROSES' ? 'badge-sebagian' : 'badge-belum' %>">
                    <%= l.status %>
                  </span>
                </div>
                <div class="small text-muted mt-1"><%= l.deskripsi %></div>
                <div class="small text-muted mt-1">
                  <%= new Date(l.createdAt).toLocaleString('id-ID', {day:'numeric',month:'short',year:'numeric',hour:'2-digit',minute:'2-digit'}) %>
                </div>
                <% if (l.balasanAdmin) { %>
                  <div class="mt-2 p-2 form-bukti">
                    <div class="small fw-semibold">Balasan Admin:</div>
                    <div class="small"><%= l.balasanAdmin %></div>
                  </div>
                <% } %>
              </div>
            <% }) %>
          <% } %>
        </div>
      </div>
    </div>

  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.socket.io/4.7.2/socket.io.min.js"></script>
<script src="/js/main.js"></script>
<script>
  mulaiPolling()

  async function kirimLaporan() {
    const judul     = document.getElementById('judul').value
    const deskripsi = document.getElementById('deskripsi').value

    if (!judul || !deskripsi) {
      tampilPesan('pesan', 'warning', 'Judul dan deskripsi harus diisi')
      return
    }

    const res  = await fetch('/api/lapor', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ judul, deskripsi })
    })
    const data = await res.json()

    if (res.ok) {
      tampilPesan('pesan', 'success', data.message)
      setTimeout(() => location.reload(), 1200)
    } else {
      tampilPesan('pesan', 'danger', data.message)
    }
  }
</script>
</body>
</html>

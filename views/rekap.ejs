<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <%- include('partials/theme-init') %>
  <title>Rekap - PayDebt</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>

<%- include('partials/navbar', { page: 'rekap', user }) %>

<div class="container my-4">
  <h5 class="fw-bold mb-4">Rekap Semua Utang Piutang</h5>

  <ul class="nav nav-tabs mb-4">
    <li class="nav-item"><button class="nav-link active" onclick="tampilTab('Pembuat', this)">Yang Saya Buat</button></li>
    <li class="nav-item"><button class="nav-link" onclick="tampilTab('Peserta', this)">Saya Ikut</button></li>
  </ul>

  <div id="tabPembuat">
    <% if (data.sebagaiPembuat.length === 0) { %>
      <p class="text-muted">Belum ada utang yang dibuat.</p>
    <% } else { %>
      <% data.sebagaiPembuat.forEach(u => { %>
        <div class="card mb-3" id="utang-<%= u.id %>">
          <div class="card-body">
            <div class="d-flex justify-content-between align-items-start">
              <div>
                <h6 class="fw-bold mb-1"><%= u.judul %></h6>
                <div class="small text-muted">
                  <%= u.tipe %> &bull;
                  Dibuat: <%= new Date(u.createdAt).toLocaleString('id-ID', {day:'numeric',month:'short',year:'numeric',hour:'2-digit',minute:'2-digit'}) %>
                  <% if (u.deadline) { %>
                    &bull; Deadline: <%= new Date(u.deadline).toLocaleDateString('id-ID', {day:'numeric',month:'long',year:'numeric'}) %>
                  <% } %>
                </div>
              </div>
              <div class="text-end">
                <span class="badge badge-<%= u.status === 'LUNAS' ? 'lunas' : u.status === 'SEBAGIAN' ? 'sebagian' : 'belum' %>">
                  <%= u.status.replace('_',' ') %>
                </span>
                <div class="fw-bold mt-1">Rp <%= u.totalAmount.toLocaleString('id-ID') %></div>
              </div>
            </div>
            <hr class="my-2">
            <div class="small mb-2">
              <strong>Peserta:</strong>
              <% u.peserta.forEach(p => { %>
                <div class="ms-2">
                  <%= p.user.name %> — Rp <%= p.jumlah.toLocaleString('id-ID') %>
                  <% if (p.sudahBayar) { %>✅<% } else if (p.requestLunas) { %>⏳ Minta Konfirmasi<% } else { %>❌<% } %>
                </div>
              <% }) %>
            </div>
            <% if (u.histori.length > 0) { %>
              <div class="small mb-2">
                <strong>Histori:</strong>
                <% u.histori.forEach(h => { %>
                  <div class="histori-item">
                    <%= h.aksi %>
                    <span class="text-muted">&bull; <%= new Date(h.createdAt).toLocaleString('id-ID', {day:'numeric',month:'short',year:'numeric',hour:'2-digit',minute:'2-digit'}) %></span>
                  </div>
                <% }) %>
              </div>
            <% } %>
            <% if (u.status !== 'LUNAS') { %>
              <button class="btn btn-sm btn-outline-danger" onclick="batalkanUtang(<%= u.id %>)">
                🗑️ Batalkan Utang Ini
              </button>
            <% } %>
          </div>
        </div>
      <% }) %>
    <% } %>
  </div>

  <div id="tabPeserta" class="d-none">
    <% if (data.sebagaiPeserta.length === 0) { %>
      <p class="text-muted">Belum ada utang yang diikuti.</p>
    <% } else { %>
      <% data.sebagaiPeserta.forEach(p => { %>
        <div class="card mb-3">
          <div class="card-body">
            <div class="d-flex justify-content-between align-items-start">
              <div>
                <h6 class="fw-bold mb-1"><%= p.utang.judul %></h6>
                <div class="small text-muted">
                  Dari: <%= p.utang.pembuat.name %> &bull;
                  <%= new Date(p.utang.createdAt).toLocaleString('id-ID', {day:'numeric',month:'short',year:'numeric',hour:'2-digit',minute:'2-digit'}) %>
                </div>
              </div>
              <div class="text-end">
                <% if (p.sudahBayar) { %>
                  <span class="badge badge-lunas">Lunas ✓</span>
                <% } else if (p.requestLunas) { %>
                  <span class="badge badge-request">Menunggu Konfirmasi</span>
                <% } else { %>
                  <span class="badge badge-belum">Belum Lunas</span>
                <% } %>
                <div class="fw-bold mt-1">Rp <%= p.jumlah.toLocaleString('id-ID') %></div>
              </div>
            </div>
            <% if (p.utang.histori.length > 0) { %>
              <hr class="my-2">
              <div class="small">
                <strong>Histori:</strong>
                <% p.utang.histori.forEach(h => { %>
                  <div class="histori-item">
                    <%= h.aksi %>
                    <span class="text-muted">&bull; <%= new Date(h.createdAt).toLocaleString('id-ID', {day:'numeric',month:'short',year:'numeric',hour:'2-digit',minute:'2-digit'}) %></span>
                  </div>
                <% }) %>
              </div>
            <% } %>
          </div>
        </div>
      <% }) %>
    <% } %>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.socket.io/4.7.2/socket.io.min.js"></script>
<script src="/js/main.js"></script>
<script>
  mulaiPolling()

  function tampilTab(nama, btn) {
    document.getElementById('tabPembuat').classList.add('d-none')
    document.getElementById('tabPeserta').classList.add('d-none')
    document.getElementById('tab' + nama).classList.remove('d-none')
    document.querySelectorAll('.nav-link').forEach(el => el.classList.remove('active'))
    btn.classList.add('active')
  }

  async function batalkanUtang(utangId) {
    if (!confirm('Yakin ingin membatalkan utang ini? Tindakan ini tidak bisa dibatalkan.')) return

    const res  = await fetch(`/api/utang/${utangId}`, { method: 'DELETE' })
    const data = await res.json()
    tampilNotifApi(res.ok, data.message)

    if (res.ok) document.getElementById(`utang-${utangId}`).remove()
  }
</script>
</body>
</html>

<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <%- include('partials/theme-init') %>
  <title>Notifikasi - PayDebt</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>

<%- include('partials/navbar', { page: 'notif', user }) %>

<div class="container my-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h5 class="fw-bold mb-0">Notifikasi</h5>
    <button class="btn btn-sm btn-outline-secondary" onclick="bacaSemua()">Tandai Semua Dibaca</button>
  </div>

  <div id="listNotif">
    <% if (notif.length === 0) { %>
      <p class="text-muted">Belum ada notifikasi.</p>
    <% } else { %>
      <% notif.forEach(n => { %>
        <div class="card notif-item <%= n.sudahBaca ? 'sudah' : '' %> mb-2" id="notif-<%= n.id %>">
          <div class="card-body py-2">
            <div class="d-flex justify-content-between align-items-start">
              <div class="flex-grow-1">
                <div class="fw-semibold small">
                  <%= n.judul %>
                  <% if (!n.sudahBaca) { %><span class="badge bg-primary ms-1" style="font-size:10px">Baru</span><% } %>
                </div>
                <div class="small text-muted"><%= n.pesan %></div>
                <div class="small text-muted">
                  <%= new Date(n.createdAt).toLocaleString('id-ID', {day:'numeric',month:'short',year:'numeric',hour:'2-digit',minute:'2-digit'}) %>
                </div>
              </div>
              <% if (!n.sudahBaca) { %>
                <button class="btn btn-sm btn-outline-secondary ms-2" onclick="bacaSatu(<%= n.id %>)">Baca</button>
              <% } %>
            </div>
          </div>
        </div>
      <% }) %>
    <% } %>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.socket.io/4.7.2/socket.io.min.js"></script>
<script src="/js/main.js"></script>
<script>
  mulaiPolling()
  async function bacaSatu(id) {
    await fetch(`/api/notif/${id}/baca`, { method: 'PATCH' })
    location.reload()
  }
  async function bacaSemua() {
    await fetch('/api/notif/baca-semua', { method: 'PATCH' })
    location.reload()
  }
</script>
</body>
</html>
